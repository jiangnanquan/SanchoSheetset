{
  "name": "sancho-sheetset",
  "productName": "SanchoSheetset",
  "version": "1.0.0",
  "description": "SanchoSheetset desktop app for splitting Excel workbooks into clean standalone exports.",
  "main": "electron/main.js",
  "author": "甘泉",
  "license": "MIT",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jiangnanquan/SanchoSheetset.git"
  },
  "homepage": "https://github.com/jiangnanquan/SanchoSheetset",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac dmg",
    "dist:win": "electron-builder --win nsis",
    "dist:dir": "electron-builder --dir"
  },
  "build": {
    "appId": "com.sancho.sheetset",
    "productName": "SanchoSheetset",
    "artifactName": "SanchoSheetset-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "web/**/*",
      "package.json",
      "!web/.DS_Store"
    ],
    "asar": true,
    "electronDist": "node_modules/electron/dist",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icons/icon.icns"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github"
      }
    ]
  },
  "devDependencies": {
    "electron": "^35.1.5",
    "electron-builder": "^26.0.12"
  }
}
